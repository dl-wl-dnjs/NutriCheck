# API base URL (no trailing slash). Used by lib/api.ts at build time (EXPO_PUBLIC_*).
#
# Simulator / web on the same machine as the API:
#   EXPO_PUBLIC_API_URL=http://127.0.0.1:8000
#
# Physical iPhone (Expo Go on Wi‑Fi): localhost / 127.0.0.1 points at the phone itself,
# not your laptop — set your laptop's LAN IP and run the API bound to 0.0.0.0, e.g.:
#   EXPO_PUBLIC_API_URL=http://192.168.1.50:8000
# Easiest on macOS: from frontend/, run  npm run start:device  (LAN + API URL helper).
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000

# Hardcoded dev user UUID until auth exists; must match a row the backend accepts.
EXPO_PUBLIC_DEV_USER_ID=a0eebc99-9c0b-4ef8-bb6d-6bb9bd380a11

# Auth (first match wins): Supabase > Clerk > dev UUID (EXPO_PUBLIC_DEV_USER_ID).
# For local work, set only one provider's keys so the other path is not picked by mistake.

# Optional: Supabase Auth (https://supabase.com). Email/password sign-in; API gets the access JWT.
# EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...
#
# Email confirmation links must open this app (scheme "nutricheck" in app.json), not http://localhost.
# Supabase → Authentication → URL Configuration → Redirect URLs: add nutricheck://** (and exp://** for Expo Go dev).
# Optional override for signUp emailRedirectTo (default: expo-linking URL for path sign-in):
# EXPO_PUBLIC_AUTH_REDIRECT_URL=nutricheck://sign-in

# Optional: Clerk (https://clerk.com). When set (and Supabase URL+anon are not), Clerk sign-in and session JWTs.
# EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
