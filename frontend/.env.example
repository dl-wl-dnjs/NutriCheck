# API base URL (no trailing slash). Used by app/lib/api.ts at build time (EXPO_PUBLIC_*).
#
# Simulator / web on the same machine as the API:
#   EXPO_PUBLIC_API_URL=http://127.0.0.1:8000
#
# Physical iPhone (Expo Go on Wi‑Fi): localhost / 127.0.0.1 points at the phone itself,
# not your laptop — set your laptop's LAN IP and run the API bound to 0.0.0.0, e.g.:
#   EXPO_PUBLIC_API_URL=http://192.168.1.50:8000
# Easiest on macOS: from frontend/, run  npm run start:device  (LAN + API URL helper).
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000

# Hardcoded dev user UUID until auth exists; must match a row the backend accepts.
EXPO_PUBLIC_DEV_USER_ID=a0eebc99-9c0b-4ef8-bb6d-6bb9bd380a11
