# Host-side API / Alembic / seed scripts: Postgres on localhost (Docker maps 5433→5432).
# Docker Compose overrides DATABASE_URL for the `api` service to postgres:5432 — keep this line for local tools.
DATABASE_URL=postgresql+psycopg2://nutricheck:nutricheck@127.0.0.1:5433/nutricheck
CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:19006
# Get a key from https://fdc.nal.usda.gov/api-key-signup.html — optional; DEMO_KEY works for limited testing
USDA_FOODDATA_API_KEY=DEMO_KEY
# true = US branded (USDA) only for scan + alternatives; faster alternatives; scoring uses label macros only (no Nutri-Score).
USDA_ONLY_MODE=false
OPENFOODFACTS_USER_AGENT=NutriCheck/1.0 (local development)
# Session JWT verification (first match wins): Supabase > Clerk > dev UUID bearer.
# For local work, set only one provider’s JWKS (and matching frontend env) unless you need both.

# Optional Supabase Auth (JWT access tokens from the mobile app)
# SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
# Optional issuer override (otherwise inferred from JWKS URL …/auth/v1)
# SUPABASE_JWT_ISSUER=https://<project-ref>.supabase.co/auth/v1
# Access token audience; leave unset for default "authenticated", or set empty to skip aud check
# SUPABASE_JWT_AUD=authenticated

# Optional Clerk session JWT verification (Expo sends Authorization: Bearer <session>)
# JWKS URL from Clerk Dashboard → API Keys → Advanced → JWT Public Key / JWKS endpoint
# CLERK_JWKS_URL=https://your-instance.clerk.accounts.com/.well-known/jwks.json
# CLERK_EXPECTED_ISS=https://your-instance.clerk.accounts.com